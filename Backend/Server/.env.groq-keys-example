# ===================================
# MULTIPLE GROQ API KEYS (ROTATION)
# ===================================

# METHOD 1: Comma-separated (Recommended)
GROQ_API_KEYS=gsk_key1_here,gsk_key2_here,gsk_key3_here

# METHOD 2: Individual keys
GROQ_API_KEY_1=gsk_first_key_here
GROQ_API_KEY_2=gsk_second_key_here
GROQ_API_KEY_3=gsk_third_key_here

# FALLBACK: Single key (if only one available)
GROQ_API_KEY=gsk_single_key_here

# ===================================
# HOW IT WORKS:
# - System automatically rotates when a key hits rate limit
# - Cooldown: 60 seconds per key
# - Tries all keys before giving up
# - Tracks usage stats per key
# ===================================
